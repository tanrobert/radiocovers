---
import Layout from '../layouts/Layout.astro';
import coversRaw from '../data/covers.json';

type Album = { albumName: string; coverUrl: string };
const coversData = coversRaw as unknown as Record<string, Album[]>;

// Appiattisci tutti gli album di tutti gli artisti
const albums: Array<{ artistName: string; albumName: string; coverUrl: string }> = [];
for (const [artistName, artistAlbums] of Object.entries(coversData)) {
  if (!Array.isArray(artistAlbums)) continue;
  for (const album of artistAlbums) {
    albums.push({ artistName, albumName: album.albumName, coverUrl: album.coverUrl });
  }
}
albums.sort((a, b) => a.artistName.localeCompare(b.artistName, 'it'));

const totalAlbums  = albums.length;
const totalArtists = Object.keys(coversData).length;
---

<Layout>
  <header>
    <h1>CALEIDOSCOPIO</h1>
    <p class="tagline">archivio di copertine progressive</p>
    <div class="stats">
      <div class="stat">
        <span class="stat-num">{totalAlbums}</span>
        <span class="stat-label">album</span>
      </div>
      <span class="stat-sep">—</span>
      <div class="stat">
        <span class="stat-num">{totalArtists}</span>
        <span class="stat-label">artisti</span>
      </div>
    </div>
    <div class="controls">
      <button id="btn-asc"  class="sort-btn active" aria-pressed="true"  title="A → Z">A <span class="arrow">↑</span></button>
      <button id="btn-desc" class="sort-btn"         aria-pressed="false" title="Z → A">A <span class="arrow">↓</span></button>
      <span class="sep-v">|</span>
      <button class="sort-btn size-btn"        data-size="250"  aria-pressed="false">SM</button>
      <button class="sort-btn size-btn active" data-size="500"  aria-pressed="true" >MD</button>
      <button class="sort-btn size-btn"        data-size="750"  aria-pressed="false">LG</button>
      <button class="sort-btn size-btn"        data-size="1000" aria-pressed="false">XL</button>
      <span class="sep-v">|</span>
      <div class="search-wrap">
        <input id="search-input" class="search-input" type="search" placeholder="Cerca…" aria-label="Cerca artista o album" />
        <button id="search-btn" class="sort-btn" title="Cerca" aria-label="Cerca">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main id="main">
    <ul class="grid" role="list">
      {albums.map(({ artistName, albumName, coverUrl }) => (
        <li class="card" data-artist={artistName.toLowerCase()} data-album={albumName.toLowerCase()}>
          <div class="img-wrap">
            <img
              src={coverUrl}
              alt={`${artistName} — ${albumName}`}
              loading="lazy"
              decoding="async"
              onerror="this.src='/placeholder.svg'"
            />
            <div class="info" aria-hidden="true">
              <p class="artist">{artistName}</p>
              <p class="album">{albumName}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  header {
    text-align: center;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--surface);
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--accent);
    text-wrap: balance;
  }

  .tagline {
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;

  }

  .stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-top: 1.25rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .stat-num {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .stat-sep {
    color: var(--muted);
    opacity: 0.3;
    font-size: 1.5rem;
    align-self: center;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(500px, 100%), 1fr));
    list-style: none;
    gap: 0.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: var(--surface);
    overflow: hidden;
    outline: 3px solid transparent;
    transition: outline-color 0.2s;
  }

  .card:hover .img-wrap {
    outline-color: var(--accent);
  }

  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem 0.6rem;
    background: linear-gradient(transparent, hsl(from var(--marrone) h s 5% / 0.85));
    opacity: 0;
    transition: opacity 0.2s;
  }

  .card:hover .info {
    opacity: 1;
  }

  .artist {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--avorio);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .album {
    font-size: 0.65rem;
    color: hsl(from var(--avorio) h s l / 0.7);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .controls {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 0.75rem;
  }

  .sort-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    touch-action: manipulation;
  }

  .sort-btn.active {
    border-color: var(--muted);
    color: var(--muted);
  }

  .sort-btn:hover:not(.active) {
    color: var(--text);
  }

  .sort-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .arrow { font-size: 0.9em; }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .search-input {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 3px 8px;
    width: 140px;
    transition: border-color 0.2s, color 0.2s, width 0.2s;
    outline: none;
  }

  .search-input:focus {
    border-color: var(--muted);
    color: var(--text);
    width: 200px;
  }

  @media (max-width: 600px) {
    .size-btn,
    .sep-v,
    .search-wrap { display: none; }
  }

  .sep-v {
    color: var(--muted);
    opacity: 0.3;
    font-size: 0.8rem;
    align-self: center;
    user-select: none;
  }
</style>

<script>
  const list    = document.querySelector('.grid') as HTMLElement;
  const btnAsc  = document.getElementById('btn-asc')!;
  const btnDesc = document.getElementById('btn-desc')!;
  let ascending = true;

  function setOrder(asc: boolean) {
    if (asc === ascending) return;
    ascending = asc;
    const items = [...list.children] as HTMLElement[];
    items.reverse().forEach(el => list.appendChild(el));
    btnAsc.classList.toggle('active', asc);
    btnDesc.classList.toggle('active', !asc);
    btnAsc.setAttribute('aria-pressed', String(asc));
    btnDesc.setAttribute('aria-pressed', String(!asc));
  }

  btnAsc.addEventListener('click',  () => setOrder(true));
  btnDesc.addEventListener('click', () => setOrder(false));

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchBtn   = document.getElementById('search-btn')!;
  const cards       = document.querySelectorAll<HTMLElement>('.card');

  function doSearch() {
    const q = searchInput.value.trim().toLowerCase();
    cards.forEach(card => {
      const text = (card.dataset.artist ?? '') + ' ' + (card.dataset.album ?? '');
      card.style.display = !q || text.includes(q) ? '' : 'none';
    });
  }

  searchBtn.addEventListener('click', doSearch);
  searchInput.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });

  const sizeBtns = document.querySelectorAll<HTMLButtonElement>('.size-btn');
  sizeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const size = btn.dataset.size!;
      list.style.gridTemplateColumns = `repeat(auto-fill, minmax(min(${size}px, 100%), 1fr))`;
      sizeBtns.forEach(b => {
        b.classList.toggle('active', b === btn);
        b.setAttribute('aria-pressed', String(b === btn));
      });
    });
  });
</script>
