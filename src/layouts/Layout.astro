---
interface Props {
  title?: string;
}
const { title = 'Radio Prog — Album Covers' } = Astro.props;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/placeholder.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Salta al contenuto</a>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* Palette base — Ambra Broadcast */
    --ambra:   hsl(36 92% 52%);   /* VU meter acceso */
    --marrone: hsl(24 22%  9%);   /* housing amplificatore */
    --avorio:  hsl(43 35% 86%);   /* carta invecchiata */

    /* Scala marrone */
    --marrone-05: hsl(from var(--marrone) h s  7%);
    --marrone-13: var(--marrone);
    --marrone-21: hsl(from var(--marrone) h s 16%);
    --marrone-34: hsl(from var(--marrone) h s 27%);
    --marrone-55: hsl(from var(--marrone) h s 42%);
    --marrone-89: hsl(from var(--marrone) h s 82%);

    /* Scala ambra */
    --ambra-13: hsl(from var(--ambra) h s 10%);
    --ambra-21: hsl(from var(--ambra) h s 18%);
    --ambra-34: hsl(from var(--ambra) h s 30%);
    --ambra-55: var(--ambra);
    --ambra-89: hsl(from var(--ambra) h s 84%);

    /* Spaziatura Fibonacci */
    --s5: 5px; --s8: 8px; --s13: 13px; --s21: 21px;
    --s34: 34px; --s55: 55px; --s89: 89px; --s144: 144px;

    /* Font weights */
    --fw-regular: 400; --fw-medium: 500; --fw-semibold: 600;
    --fw-bold: 700; --fw-extrabold: 800;

    /* Semantic — dark theme */
    --bg:      var(--marrone-05);
    --surface: var(--marrone-21);
    --text:    var(--avorio);
    --muted:   var(--marrone-55);
    --accent:  var(--ambra);
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
  }

  body {
    min-height: 100vh;
    padding: 2rem 1.5rem 4rem;
  }

  a, button, [role="button"] {
    touch-action: manipulation;
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 13px;
    padding: 8px 21px;
    background: var(--accent);
    color: var(--marrone);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    z-index: 9999;
    transition: top 0.2s;
    text-decoration: none;
  }
  .skip-link:focus { top: 13px; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
