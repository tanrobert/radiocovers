---
interface Props {
  title?: string;
}
const { title = 'Radio Prog — Album Covers' } = Astro.props;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/placeholder.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Salta al contenuto</a>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* Palette base */
    --rosso:  hsl(8 87% 54%);
    --nero:   hsl(0 12% 13%);
    --giallo: hsl(55 89% 53%);
    --verde:  hsl(143 88% 54%);
    --bianco: hsl(0 15% 89%);

    /* Scala nero */
    --nero-05: hsl(from var(--nero) h s 7%);
    --nero-13: var(--nero);
    --nero-21: hsl(from var(--nero) h s 19%);
    --nero-34: hsl(from var(--nero) h s 30%);
    --nero-55: hsl(from var(--nero) h s 46%);
    --nero-89: hsl(from var(--nero) h s 85%);

    /* Scala rosso */
    --rosso-13: hsl(from var(--rosso) h s 10%);
    --rosso-21: hsl(from var(--rosso) h s 18%);
    --rosso-34: hsl(from var(--rosso) h s 30%);
    --rosso-55: var(--rosso);
    --rosso-89: hsl(from var(--rosso) h s 82%);

    /* Spaziatura Fibonacci */
    --s5: 5px; --s8: 8px; --s13: 13px; --s21: 21px;
    --s34: 34px; --s55: 55px; --s89: 89px; --s144: 144px;

    /* Font weights */
    --fw-regular: 400; --fw-medium: 500; --fw-semibold: 600;
    --fw-bold: 700; --fw-extrabold: 800;

    /* Semantic — dark theme */
    --bg:      var(--nero-05);
    --surface: var(--nero-21);
    --text:    var(--bianco);
    --muted:   var(--nero-55);
    --accent:  var(--rosso);
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
  }

  body {
    min-height: 100vh;
    padding: 2rem 1.5rem 4rem;
  }

  a, button, [role="button"] {
    touch-action: manipulation;
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 13px;
    padding: 8px 21px;
    background: var(--accent);
    color: var(--bianco);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    z-index: 9999;
    transition: top 0.2s;
    text-decoration: none;
  }
  .skip-link:focus { top: 13px; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
